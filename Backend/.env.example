# RepoMind Backend Environment Configuration
# Copy this file to .env and fill in the values

# Application
PORT=3001
NODE_ENV=development

# AI Provider (openai | ollama | nvidia)
AI_PROVIDER=openai

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# NVIDIA NIM (used when AI_PROVIDER=nvidia)
NVIDIA_API_KEY= 
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# Ollama (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB Cloud
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_CODE_CHUNKS=code_chunks
CHROMA_COLLECTION_DEPENDENCY_GRAPH=dependency_graph
CHROMA_COLLECTION_ARCHITECTURE_NODES=architecture_nodes
CHROMA_COLLECTION_DOCUMENTATION_NODES=documentation_nodes

# GitHub
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com

# Database (relational - SQLite default)
DATABASE_URL=file:./repomind.db

# Jobs
JOB_CONCURRENCY=3
JOB_CLONE_TIMEOUT_MS=300000
JOB_PARSE_TIMEOUT_MS=600000

# Logging
LOG_LEVEL=info
